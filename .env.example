# Copy this file to `.env` and adjust values for your environment.

# Where the pipeline stores normalized data and extracted artifacts.
DATA_DIR=data

# Logging verbosity.
LOG_LEVEL=INFO

# HTTP request settings.
REQUEST_TIMEOUT_SECS=30

# Optional: identify your client to upstream APIs.
USER_AGENT=ai-security-trend-finder/1.0
ARXIV_USER_AGENT=ai-trend-intel/1.0 (research; contact: your-email@example.com)

# Optional: tokens for connectors that require authentication.
GITHUB_TOKEN=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: LLM provider used for summarization/classification (if enabled).
LLM_PROVIDER=
OPENAI_MODEL=
ANTHROPIC_MODEL=

# Optional: cap items per ingestion run (useful for testing).
MAX_ITEMS_PER_RUN=200

